      "parameters": {
        "jsCode": "// 1. Get the fully fuzzy-merged JSON string that the LLM generated\nconst llmOutputString = $input.first().json.text;\n\n// 2. Parse it to ensure it is valid JSON\nconst parsedMemory = JSON.parse(llmOutputString);\n\n// 3. Format it safely for the GitHub Update node to save\nreturn { \n    json: { \n        file_content: JSON.stringify(parsedMemory, null, 2) \n    } \n};\n"
