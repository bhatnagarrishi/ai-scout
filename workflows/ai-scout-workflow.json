        "jsCode": "const items = $(\"RSS Read\").all();\nconst ingestedContent = $(\"Get Ingested Urls\").all()[0].json.content;\nconst ingestedUrls = JSON.parse(Buffer.from(ingestedContent, 'base64').toString('utf8')).map(u => u.trim());\n\nreturn items.filter(item => {\n  const url = (item.json.link || item.json.guid || \"\").trim();\n  return url && !ingestedUrls.includes(url);\n});"
