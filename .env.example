# ==========================================
# AI Scout & Mentor - Example Environment
# ==========================================
# 
# Instructions:
# Copy this file to `.env` and fill in your actual API keys.
# DO NOT commit your actual `.env` file to version control!
# Only commit structural changes back to this `.env.example` file.

# ---- LLMs ----
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ---- External Services ----
YOUTUBE_API_KEY=your_google_cloud_youtube_api_key_here
GITHUB_PAT=your_github_personal_access_token_here
NGROK_DOMAIN=your-static-domain.ngrok-free.dev
WEBHOOK_URL=https://your-static-domain.ngrok-free.dev

# ---- AWS Bedrock Agents ----
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
BEDROCK_AGENT_ID=your_agent_id
BEDROCK_AGENT_ALIAS_ID=TSTALIASID
